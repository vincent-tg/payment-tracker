# Email Configuration
# For Gmail, use an "App Password" (not your regular password)
# Enable 2FA and generate app password: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your-email@gmail.com
# Preferred (secure):
EMAIL_APP_PASSWORD=your-app-password
# Backward compatibility (legacy):
# EMAIL_PASSWORD=your-app-password
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Database Configuration
DATABASE_PATH=payment_tracker.db
# PostgreSQL / Supabase (preferred in production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# SUPABASE_CONNECTION_STRING=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres

# Application Settings
# LOG_LEVEL=info (debug, info, warn, error)